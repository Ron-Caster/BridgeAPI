{
  "manifest_version": 2,
  "name": "ChatGPT CLI Bridge",
  "version": "1.0",
  "description": "Bridges a local Python CLI to ChatGPT via WebSockets",
  "permissions": [
    "tabs", 
    "*://*.chatgpt.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' ws://127.0.0.1:8765 ws://localhost:8765;"
}